{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fast Todo",
  "version": "0.1.0",
  "identifier": "com.fasttodo.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Fast Todo",
        "width": 880,
        "height": 700
      },
      {
        "label": "today-popover",
        "title": "Today",
        "width": 340,
        "height": 480,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": true,
        "minWidth": 280,
        "minHeight": 320
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
