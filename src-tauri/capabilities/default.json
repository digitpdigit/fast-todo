{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for main and today popover",
  "windows": ["main", "today-popover"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:event:default",
    "core:window:allow-hide",
    "core:window:allow-set-position",
    "core:window:allow-start-dragging",
    "notification:default"
  ]
}
